{
  "name": "agent-octopus",
  "version": "0.1.0",
  "private": true,
  "description": "Intelligent routing layer that connects user needs to Skills and MCPs without installation",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0",
    "tsx": "^4.7.0"
  },
  "license": "Apache-2.0"
}

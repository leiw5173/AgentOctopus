{
  "name": "@agentoctopus/gateway",
  "version": "0.3.1",
  "description": "AgentOctopus gateways: Slack, Discord, Telegram bots and agent-to-agent HTTP protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "agentoctopus-gateway": "./dist/bin/start-agent-gateway.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:agent": "tsx src/bin/start-agent-gateway.ts",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentoctopus/core": "workspace:*",
    "@agentoctopus/registry": "workspace:*",
    "@agentoctopus/adapters": "workspace:*",
    "@slack/bolt": "^3.19.0",
    "discord.js": "^14.15.0",
    "telegraf": "^4.16.3",
    "express": "^4.19.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/leiw5173/AgentOctopus"
  },
  "keywords": ["ai", "agent", "slack", "discord", "telegram", "bot", "mcp", "gateway"]
}

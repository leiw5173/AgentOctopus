{
  "name": "agentoctopus",
  "version": "0.4.4",
  "description": "Intelligent routing layer that connects user needs to Skills and MCPs — install once, use everything",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "octopus": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentoctopus/registry": "workspace:*",
    "@agentoctopus/adapters": "workspace:*",
    "@agentoctopus/core": "workspace:*",
    "@agentoctopus/gateway": "workspace:*",
    "@agentoctopus/cli": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leiw5173/AgentOctopus.git"
  },
  "keywords": ["ai", "agent", "llm", "mcp", "routing", "skills", "slack", "discord", "telegram", "cli", "openai", "ollama", "gemini"]
}

LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4
OPENAI_API_KEY=
OPENAI_BASE_URL=https://your-openai-compatible-base-url/v1

EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
EMBED_API_KEY=
EMBED_BASE_URL=https://your-embedding-base-url/v1
RERANK_MODEL=gpt-4o-mini

GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

REGISTRY_PATH=./registry/skills
RATINGS_PATH=./registry/ratings.json

# Deployment mode: "cloud" (full gateway + web UI) or "local" (gateway only, default)
DEPLOY_MODE=local
# Cloud instance URL for skill sync (local mode only)
CLOUD_URL=
# Auto-sync skills from cloud on startup (default: true)
SYNC_ON_STARTUP=true

# ──────────────────────────────────────────────────────────
# AgentOctopus Configuration
# Run `octopus onboard` for interactive setup.
# ──────────────────────────────────────────────────────────

# LLM Provider (openai | gemini | ollama)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Embeddings
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
EMBED_API_KEY=
EMBED_BASE_URL=https://api.openai.com/v1
RERANK_MODEL=gpt-4o-mini

# Optional: Gemini
GEMINI_API_KEY=

# Optional: Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Registry
REGISTRY_PATH=./registry/skills
RATINGS_PATH=./registry/ratings.json

# Execution / Deployment Mode (local | cloud | hybrid)
EXECUTION_MODE=local
DEPLOY_MODE=local
CLOUD_GATEWAY_URL=https://api.agentoctopus.dev
CLOUD_URL=
CLOUD_API_KEY=

# Auto-sync skills from cloud on startup (default: true)
SYNC_ON_STARTUP=true

# Disabled skills (comma-separated list)
# DISABLED_SKILLS=ip-lookup,agentoctopus-openclaw

# ── Security (Cloud Gateway) ─────────────────────────────
AUTH_ENABLED=true
RATE_LIMIT_ENABLED=true
ADMIN_API_KEY=
API_KEYS_PATH=./api-keys.json
AUDIT_LOG_DIR=./logs

# CORS (comma-separated origins, or * for all)
CORS_ALLOWED_ORIGINS=*

# ── IM Bot Tokens ─────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_TOKEN=xapp-...
# DISCORD_TOKEN=...
# TELEGRAM_BOT_TOKEN=...

# ── Payment (Stripe) — Phase 3 ───────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_ENTERPRISE=price_xxx
